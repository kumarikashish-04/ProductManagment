# Backend Environment Variables

# Server Port
PORT=5000

# MongoDB Connection URI
MONGO_URI=mongodb://localhost:27017/aasamedchem

# JWT Secret Key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_jwt_secret_key_here_replace_with_actual_value

# Node Environment
NODE_ENV=development

# CORS Settings
CORS_ORIGIN=http://localhost:5173

# Email Settings (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Deployment Settings
VERCEL_URL=https://your-backend-url.vercel.app
